

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Backend Server Port (Default is 3000 for server middleware, set to 8000 for standalone backend)
SERVER_PORT=8000

# PostgreSQL database connection string for Prisma ORM
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/purplexity?schema=public"

# Tavily API Search Key
TAVILY_API_KEY=""

# OpenRouter API Completions Key
OPENROUTER_API_KEY=""

# JWT encryption secret for backend session tokens
JWT_SECRET="purplexity-super-secret-key-2026"

# Firebase Client-Side configurations (Vite requires VITE_ prefix for frontend injection)
VITE_FIREBASE_API_KEY="AIzaSyC1l7VjJMj9DT2Z41G8bEr_eIO75bLDC1g"
VITE_FIREBASE_AUTH_DOMAIN="purplexity-4eef7.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="purplexity-4eef7"
VITE_FIREBASE_STORAGE_BUCKET="purplexity-4eef7.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="589953643775"
VITE_FIREBASE_APP_ID="1:589953643775:web:0f48425e0c63b122bd48ca"

# Firebase Backend signature validation configuration
FIREBASE_PROJECT_ID="purplexity-4eef7"

